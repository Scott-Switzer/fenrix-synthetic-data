__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
.venv/
.env/

# Lock files (not using pipenv/poetry/uv lock)
Pipfile.lock
poetry.lock
uv.lock

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

